# Copie para `backend/.env` (nunca commite o `.env` real).
#
# Admin inicial opcional: criado na subida do backend se login+password estiverem preenchidos.
# Em Production também exige BootstrapAdmin__Enabled=true (ou variável em appsettings).
#
# Exemplo de login (CPF sem formatação):
BOOTSTRAP_ADMIN__LOGIN=12365382770
BOOTSTRAP_ADMIN__PASSWORD=tThihi123
# Opcional — se vazio, usa {login}@bootstrap.local
# BOOTSTRAP_ADMIN__EMAIL=
#
# Se o utilizador já existir: ajusta grupo para Administrador. Para redefinir hash da senha:
# BOOTSTRAP_ADMIN__UPDATEPASSWORD=true
#
# Permitir bootstrap fora de Development (staging/prod) — use com cuidado:
# BOOTSTRAP_ADMIN__ENABLED=true
