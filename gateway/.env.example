# Gateway listener (host:port). Defaults to :8080.
LISTEN_ADDR=:8080

# Environment label, used by the structured logger. e.g. development, staging, production.
ENV=development

# Log level: debug | info | warn | error. Defaults to info.
LOG_LEVEL=info

# Upstream backend base URL. The proxy layer is a placeholder in this skeleton
# and does not forward traffic yet, but the value is read so config wiring is
# verified end to end.
BACKEND_URL=http://localhost:5101

# Comma-separated list of allowed origins for CORS. Empty disables CORS.
# Example: http://localhost:3000,http://localhost:3001
ALLOWED_ORIGINS=

# Read/write/idle timeouts in seconds. Reasonable defaults are applied if unset.
READ_TIMEOUT_SECONDS=10
WRITE_TIMEOUT_SECONDS=15
IDLE_TIMEOUT_SECONDS=60
SHUTDOWN_TIMEOUT_SECONDS=15

# Per-IP rate limit applied to /api/*. Health probes are NOT rate-limited.
# Set RATE_LIMIT_RPS=0 or RATE_LIMIT_BURST=0 to disable (default).
# Example: 50 requests/second steady, allowing bursts of up to 100.
RATE_LIMIT_RPS=0
RATE_LIMIT_BURST=0
RATE_LIMIT_TTL_SECONDS=600
