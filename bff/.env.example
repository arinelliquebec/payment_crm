# Porta do BFF
PORT=3001

# URL base do backend .NET (sem /api no final)
DOTNET_BACKEND_URL=https://arrighi-bk-bzfmgxavaxbyh5ej.brazilsouth-01.azurewebsites.net

# Segredo para assinar o JWT interno do BFF
JWT_SECRET=troque-por-um-segredo-forte-em-producao

# Expiração do JWT (ex: 8h, 1d, 7d)
JWT_EXPIRY=8h

# Domínio do cookie (usar .arrighicrm.com para subdomínios também)
COOKIE_DOMAIN=arrighicrm.com

# Origin(s) permitida(s) para CORS — separadas por vírgula se múltiplas
FRONTEND_ORIGIN=https://arrighicrm-front-v1.vercel.app,https://arrighicrm.com,https://www.arrighicrm.com

# Ambiente (development | production)
NODE_ENV=production
